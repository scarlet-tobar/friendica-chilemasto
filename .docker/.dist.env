# Copy this file to .docker/.env.local and adjust as needed
# DOCKER ENVIRONMENT CONFIGURATION

# Database
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=friendica
MYSQL_USER=friendica
MYSQL_PASSWORD=friendica
MYSQL_ROOT_PASSWORD=root
PHPMYADMIN_PORT=8086

# Redis
REDIS_HOST=redis

# PHP Settings
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=300

# Webserver setup
SERVER_NAME=localhost
SERVER_PORT=8080
PROJECT_DIR=/var/www/html
FRIENDICA_URL=http://${SERVER_NAME}:${SERVER_PORT}

# Test users
ADMIN_NICK=admin
ADMIN_PASSW=admin
USER_NICK=user
USER_PASSW=user

# Friendica
# Add your Friendica specific settings here if needed
