#: mod/lostpass.php:28
msgid "No valid account found."
msgstr "Não foi encontrada nenhuma conta válida."

#: mod/lostpass.php:40
msgid "Password reset request issued. Check your email."
msgstr "A solicitação para reiniciar sua senha foi encaminhada. Verifique seu e-mail."

#: mod/lostpass.php:46
#, php-format
msgid ""
"\n"
"\t\tDear %1$s,\n"
"\t\t\tA request was recently received at \"%2$s\" to reset your account\n"
"\t\tpassword. In order to confirm this request, please select the verification link\n"
"\t\tbelow or paste it into your web browser address bar.\n"
"\n"
"\t\tIf you did NOT request this change, please DO NOT follow the link\n"
"\t\tprovided and ignore and/or delete this email, the request will expire shortly.\n"
"\n"
"\t\tYour password will not be changed unless we can verify that you\n"
"\t\tissued this request."
msgstr "\nOlá %1$s​,\nUma requisição foi recebida em \"%2$s\" para reiniciar a senha da sua conta. \nPara confirmar essa requisição, por favor selecione o link de verificação abaixo \nou cole-o na barra de endereço do seu navegador.\n\nCaso você não tenha requisitado essa mudança, por favor NÃO clique neste \nlink e ignore e/ou apague esse e-mail. A requisição vai expirar em breve.\n\nSua senha não será mudada a menos que possamos verificar que você efetuou \nesta requisição."

#: mod/lostpass.php:57
#, php-format
msgid ""
"\n"
"\t\tFollow this link soon to verify your identity:\n"
"\n"
"\t\t%1$s\n"
"\n"
"\t\tYou will then receive a follow-up message containing the new password.\n"
"\t\tYou may change that password from your account settings page after logging in.\n"
"\n"
"\t\tThe login details are as follows:\n"
"\n"
"\t\tSite Location:\t%2$s\n"
"\t\tLogin Name:\t%3$s"
msgstr "\nClique nesse link, assim que possível, para verificar sua identidade.\n\n\t\t%1$s\n\nVocê receberá, então, uma mensagem contendo a nova senha.\nVocê pode mudar esta senha na página de configuração da sua conta após se autenticar.\n\nOs detalhes de autenticação são os seguintes:\n\n\t\tLocalização do site: %2$s\n\t\tNome da conta: %3$s"

#: mod/lostpass.php:72
#, php-format
msgid "Password reset requested at %s"
msgstr "Foi feita uma solicitação de redefinição da senha em %s"

#: mod/lostpass.php:88
msgid ""
"Request could not be verified. (You may have previously submitted it.) "
"Password reset failed."
msgstr "Não foi possível verificar a solicitação (você pode tê-la submetido anteriormente). A senha não foi redefinida."

#: mod/lostpass.php:101
msgid "Request has expired, please make a new one."
msgstr "A requisição expirou, por favor faça um nova."

#: mod/lostpass.php:116
msgid "Forgot your Password?"
msgstr "Esqueceu a sua senha?"

#: mod/lostpass.php:117
msgid ""
"Enter your email address and submit to have your password reset. Then check "
"your email for further instructions."
msgstr "Digite o seu endereço de e-mail e clique em 'Redefinir' para prosseguir com o reinício da sua senha. Após isso, verifique seu e-mail para mais instruções."

#: mod/lostpass.php:118 src/Module/Security/Login.php:167
msgid "Nickname or email"
msgstr "Identificação ou e-mail"

#: mod/lostpass.php:119
msgid "Reset my password"
msgstr "Redefinir minha senha"

#: mod/lostpass.php:134 src/Module/Security/Login.php:179
msgid "Password Reset"
msgstr "Redefinir a senha"

#: mod/lostpass.php:135
msgid "Your password has been reset as requested."
msgstr "Sua senha foi reiniciada, conforme solicitado."

#: mod/lostpass.php:136
msgid "Your new password is"
msgstr "Sua nova senha é"

#: mod/lostpass.php:137
msgid "Save or copy your new password - and then"
msgstr "Salve ou copie a sua nova senha e, então"

#: mod/lostpass.php:138
msgid "click here to login"
msgstr "clique aqui para entrar"

#: mod/lostpass.php:139
msgid ""
"Your password may be changed from the <em>Settings</em> page after "
"successful login."
msgstr "Sua senha pode ser alterada na página de <em>Configurações</em> após você entrar em sua conta."

#: mod/lostpass.php:143
msgid "Your password has been reset."
msgstr "Sua senha foi reiniciada."

#: mod/lostpass.php:146
#, php-format
msgid ""
"\n"
"\t\t\tDear %1$s,\n"
"\t\t\t\tYour password has been changed as requested. Please retain this\n"
"\t\t\tinformation for your records (or change your password immediately to\n"
"\t\t\tsomething that you will remember).\n"
"\t\t"
msgstr "\nCaro %1$s,\n\nSua senha foi alterada, conforme requisitado. Por favor, guarde essa \nnova senha ou mude-a imediatamente para alguma outra mais fácil\npara você se lembrar."

#: mod/lostpass.php:152
#, php-format
msgid ""
"\n"
"\t\t\tYour login details are as follows:\n"
"\n"
"\t\t\tSite Location:\t%1$s\n"
"\t\t\tLogin Name:\t%2$s\n"
"\t\t\tPassword:\t%3$s\n"
"\n"
"\t\t\tYou may change that password from your account settings page after logging in.\n"
"\t\t"
msgstr "\n\t\t\tSeus detalhes de login são os seguintes:\n\n\t\t\tLocalização do site:\t%1$s\n\t\t\tIdentificador:\t%2$s\n\t\t\tSenha:\t%3$s\n\n\t\t\tVocê pode trocar a senha a partir das configurações da sua conta, após autenticar-se.\n\t\t"

